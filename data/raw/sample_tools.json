[
  {
    "type": "function",
    "function": {
      "name": "search_flights",
      "description": "Search for available flights between two airports on a given date. Returns a list of flight options with airline, departure time, arrival time, and a flight_id.",
      "parameters": {
        "type": "object",
        "properties": {
          "origin": {
            "type": "string",
            "description": "IATA airport code for the departure airport (e.g. 'JFK', 'LAX')"
          },
          "destination": {
            "type": "string",
            "description": "IATA airport code for the arrival airport"
          },
          "date": {
            "type": "string",
            "description": "Travel date in YYYY-MM-DD format"
          },
          "cabin_class": {
            "type": "string",
            "enum": ["economy", "premium_economy", "business", "first"],
            "description": "Cabin class preference"
          },
          "num_passengers": {
            "type": "integer",
            "description": "Number of passengers (default 1)",
            "minimum": 1,
            "maximum": 9
          }
        },
        "required": ["origin", "destination", "date"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "get_flight_details",
      "description": "Retrieve detailed information about a specific flight including price, seat availability, and baggage policy.",
      "parameters": {
        "type": "object",
        "properties": {
          "flight_id": {
            "type": "string",
            "description": "Unique flight identifier returned by search_flights"
          },
          "currency": {
            "type": "string",
            "description": "Currency code for price display (e.g. 'USD', 'EUR')",
            "default": "USD"
          }
        },
        "required": ["flight_id"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "book_flight",
      "description": "Book a flight for one or more passengers. Returns a booking confirmation number and PNR.",
      "parameters": {
        "type": "object",
        "properties": {
          "flight_id": {
            "type": "string",
            "description": "Flight identifier from search_flights or get_flight_details"
          },
          "passenger_name": {
            "type": "string",
            "description": "Full legal name of the primary passenger"
          },
          "passenger_email": {
            "type": "string",
            "description": "Email address for booking confirmation"
          },
          "seat_preference": {
            "type": "string",
            "enum": ["window", "middle", "aisle", "no_preference"],
            "description": "Seat location preference"
          }
        },
        "required": ["flight_id", "passenger_name", "passenger_email"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "search_hotels",
      "description": "Search for available hotels in a city for given check-in and check-out dates. Returns a list of hotels with hotel_id, name, star rating, and nightly rate.",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "description": "City name to search hotels in"
          },
          "checkin_date": {
            "type": "string",
            "description": "Check-in date in YYYY-MM-DD format"
          },
          "checkout_date": {
            "type": "string",
            "description": "Check-out date in YYYY-MM-DD format"
          },
          "guests": {
            "type": "integer",
            "description": "Number of guests",
            "minimum": 1
          },
          "max_price_per_night": {
            "type": "number",
            "description": "Maximum price per night in USD"
          },
          "star_rating": {
            "type": "integer",
            "description": "Minimum hotel star rating (1-5)",
            "minimum": 1,
            "maximum": 5
          }
        },
        "required": ["city", "checkin_date", "checkout_date"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "book_hotel",
